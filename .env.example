# ============================================================================
# Ponto Backend — Environment Variables
# ----------------------------------------------------------------------------
# Copy this file to `.env` (never commit it) and fill in real values.
# Every variable below is actively read by the codebase; anything missing here
# but used at runtime is a bug — please keep this file in sync.
# Validation lives in src/infra/config/env.schema.ts (boot fails on bad env).
# ============================================================================

# --- Runtime --------------------------------------------------------------------
# `development` | `production` | `test`
# Controls Prisma log verbosity (production silences query logs).
NODE_ENV=development

# HTTP port NestJS binds to. Defaults to 3001 when unset.
PORT=3001

# Server timezone — drives WorkDay date resolution and expectedMinutes.
# Studio is in Sinop/MT (UTC-4, no DST). Keep this constant in production.
TZ=America/Cuiaba

# --- Database -------------------------------------------------------------------
# Postgres connection string consumed by Prisma (prisma.config.ts) and the
# shared PrismaClient singleton (src/infra/database/prisma.instance.ts).
DATABASE_URL=postgresql://ponto:ponto@localhost:5432/ponto?schema=public

# --- Auth (JWT) -----------------------------------------------------------------
# Secret used by AuthModule + JwtTokenServiceImpl to sign and verify session
# tokens. MUST be a long random string in any non-local environment.
JWT_SECRET=change-me-in-production-this-must-be-a-long-random-string

# jsonwebtoken-compatible expiry (e.g. `7d`, `12h`, `30m`). Defaults to `7d`.
JWT_EXPIRES_IN=7d

# Bcrypt cost factor for password hashing. 10 is a sane default; raise for
# stricter security (and slower logins).
BCRYPT_SALT_ROUNDS=10

# --- CORS -----------------------------------------------------------------------
# Comma-separated list of allowed origins for the browser frontend.
CORS_ORIGINS=http://localhost:3000

# --- Studio IP allowlist (optional) --------------------------------------------
# Comma-separated CIDR ranges considered "inside the studio". When set, punches
# from outside are flagged (not blocked) for HR review.
# Example: STUDIO_IP_RANGES=200.123.0.0/24,2804:abcd::/32
STUDIO_IP_RANGES=

# --- SMTP (announcements) ------------------------------------------------------
# Used by the announcement event handler to email the team when a new
# announcement is published. Leave SMTP_HOST blank to disable email entirely.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=ponto@studio.local

# --- Avatar upload --------------------------------------------------------------
# Local directory where uploaded avatars are stored (multer dest). Served as
# static assets by the app. Tech debt: migrate to S3 if usage grows.
AVATAR_UPLOAD_DIR=uploads/avatars
