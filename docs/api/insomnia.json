      "body": { "mimeType": "application/json", "text": "{\"name\":\"Padrão 8h\",\"scheduleData\":{\"monday\":{\"start\":\"09:00\",\"end\":\"18:00\",\"breakMinutes\":60},\"tuesday\":{\"start\":\"09:00\",\"end\":\"18:00\",\"breakMinutes\":60},\"wednesday\":{\"start\":\"09:00\",\"end\":\"18:00\",\"breakMinutes\":60},\"thursday\":{\"start\":\"09:00\",\"end\":\"18:00\",\"breakMinutes\":60},\"friday\":{\"start\":\"09:00\",\"end\":\"18:00\",\"breakMinutes\":60}}}" }
    },
