      "body": { "mimeType": "application/json", "text": "{\"userId\":\"USER_UUID\",\"startDate\":\"2026-04-21\",\"endDate\":\"2026-04-23\",\"attachmentUrl\":\"https://storage/atestado.pdf\",\"reason\":\"Gripe\"}" }
